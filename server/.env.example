# Copy this file to .env and fill in your values.
# server/.env is gitignored — never commit real credentials.

# Path to the SQLite database file.
# Defaults to <project>/data/cooking-rules.db when unset.
# Electron sets this at runtime to app.getPath('userData')/cooking-rules.db
# DB_PATH=/absolute/path/to/cooking-rules.db

# Express
PORT=3000

# Comma-separated list of origins the API will accept
CORS_ORIGINS=http://localhost:4200,http://localhost:4201
